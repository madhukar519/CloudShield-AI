# Cloud Security Policy Chatbot — Environment Variables
# Copy this file to .env and fill in your API key

# ── Required (Pick one provider in config.py) ──────────────
# OpenAI API key (starts with sk-)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Amazon Bedrock credentials (if using bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Ollama settings (if using ollama - for local-only air-gapped use)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Optional overrides ────────────────────────────────────
# Uncomment to override defaults set in config.py
# MODEL_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L12-v2
